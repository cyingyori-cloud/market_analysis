{
  "$schema": "railway.app.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPkgs": ["...defaults", "nodejs_20"],
    "buildCommand": "cd server && npm install"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "cd server && npm start"
  }
}
