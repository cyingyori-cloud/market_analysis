{
  "$schema": "railway.app.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPkgs": ["...defaults", "nodejs_20"],
    "installCommand": "npm install",
    "buildCommand": "npm install tsx && npx tsc --noEmit || true"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npx tsx server/index.ts"
  }
}
