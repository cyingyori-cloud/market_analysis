# Copy this file to `.env` and replace the placeholder values below.
# Do not commit real credentials or production URLs.

# Primary API service
PORT=3001
NODE_ENV=development

# Frontend URL used for CORS in local or deployed environments
FRONTEND_URL=https://your-frontend.example.com

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/market_analysis
PGSSL=false

# Legacy MongoDB setting kept only for transitional compatibility.
# Remove after the backend is fully migrated off MongoDB.
MONGODB_URI=mongodb://localhost:27017/4s-intelligence

# AI provider
SILICON_FLOW_API_KEY=your_siliconflow_api_key

# Auth
AUTH_DISABLED=true
API_KEY=replace_with_a_real_api_key

# Crawler / worker
API_BASE=http://127.0.0.1:3001
CRAWLER_INTERVAL_HOURS=6
