# 4S竞品情报系统 - 环境变量配置

# ===================
# 前端配置
# ===================

# 是否使用静态数据（true=演示模式，false=连接真实API）
VITE_USE_STATIC_DATA=true

# API基础地址（当VITE_USE_STATIC_DATA=false时使用）
VITE_API_BASE_URL=/api

# ===================
# 后端配置
# ===================

# 服务器端口
PORT=3001

# MongoDB连接字符串
# 本地开发: mongodb://localhost:27017/4s-intelligence
# MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/4s-intelligence
MONGODB_URI=mongodb://localhost:27017/4s-intelligence

# Anthropic API Key (用于AI分析)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (备选)
OPENAI_API_KEY=sk-xxxxx

# 爬虫配置
API_BASE=http://localhost:3001
